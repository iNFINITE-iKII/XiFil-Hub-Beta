# Database (Neon PostgreSQL)
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Session
SESSION_SECRET=your-long-random-secret-here

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# App URL (your Railway public domain, e.g. https://your-app.up.railway.app)
# RAILWAY_PUBLIC_DOMAIN is set automatically by Railway — APP_URL is optional override
APP_URL=https://your-app.up.railway.app

# Runtime
NODE_ENV=production
LOG_LEVEL=info
# PORT is set automatically by Railway — do not override
